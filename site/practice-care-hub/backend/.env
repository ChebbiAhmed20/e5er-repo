NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://virela:changeme@localhost:5432/virela
JWT_ACCESS_SECRET=virela_access_secret_key_32_chars_long_minimum
JWT_REFRESH_SECRET=virela_refresh_secret_key_32_chars_long_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:8082,http://localhost:5173
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
POSTGRES_USER=virela
POSTGRES_PASSWORD=changeme
POSTGRES_DB=virela

